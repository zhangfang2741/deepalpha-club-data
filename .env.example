FMP_API_KEY=<your-fmp-api-key>

# PostgreSQL (Neon, SSL required)
POSTGRES_HOST=<your-neon-host>.neon.tech
POSTGRES_PORT=5432
POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=<your-password>
POSTGRES_SSL=true

# Valkey (Upstash, SSL required)
VALKEY_HOST=<your-upstash-host>.upstash.io
VALKEY_PORT=6379
VALKEY_PASSWORD=<your-password>
VALKEY_SSL=true

# Finnhub
FINNHUB_API_KEY=<your-finnhub-api-key>

# MiniMax（AI 摘要，已有账号可复用）
MINIMAX_API_KEY=<your-minimax-api-key>

# ── YouTube 创作者新闻流 Pipeline ──────────────────────────
# Telegram Bot Token（通过 @BotFather 创建）
TELEGRAM_BOT_TOKEN=<your-bot-token>

# 目标频道 ID：公开频道用 @username，私有频道用 -100xxxxxxxxxx
# 留空则进入干运行模式（仅打印消息，不发送）
TELEGRAM_CHANNEL_ID=

# 频道配置 YAML 路径（默认：config/youtube_channels.yaml）
YOUTUBE_CHANNELS_YAML=config/youtube_channels.yaml

# YouTube cookies 文件路径（Netscape 格式，用于访问需登录的字幕，留空则不使用）
# 如何导出：Chrome 安装 "Get cookies.txt LOCALLY" 插件 → 访问 youtube.com → 导出
YOUTUBE_COOKIES_FILE=

# Groq API Key（用于 Whisper 音频转录，免费注册：console.groq.com）
GROQ_API_KEY=
